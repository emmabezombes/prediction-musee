# ==========================================================
# RANDOM FOREST - PREDICTION DE LA FREQUENTATION DES MUSEES
# ==========================================================
# Objectif :
# Apprendre, à partir des données passées, à prédire
# la fréquentation annuelle d’un musée (variable numérique).
# ==========================================================


# --------------------------
# 1) IMPORTS
# --------------------------
# On importe les librairies nécessaires :
# - pandas / numpy : manipulation des données
# - scikit-learn : machine learning

import os
import numpy as np
import pandas as pd

from sklearn.model_selection import train_test_split
from sklearn.preprocessing import OneHotEncoder
from sklearn.compose import ColumnTransformer
from sklearn.pipeline import Pipeline
from sklearn.impute import SimpleImputer

from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_absolute_error, r2_score


# --------------------------
# 2) CHARGEMENT DES DONNEES
# --------------------------
# On charge le dataset final utilisé pour le ML.
# Ce dataset contient :
# - les caractéristiques des musées (features)
# - la fréquentation annuelle (target)

df = pd.read_csv("output/df_modele_musees.csv")

print("Dimensions du dataset :", df.shape)
display(df.head())


# --------------------------
# 3) DEFINITION DE LA TARGET
# --------------------------
# La target est la variable que l’on cherche à prédire.
# Ici : la fréquentation annuelle (un nombre de visiteurs).

TARGET = "frequentation_annuelle"  # adapte si le nom diffère

# Séparation :
# X = variables explicatives
# y = variable cible
X = df.drop(columns=[TARGET])
y = df[TARGET]

# On s’assure que la target est bien numérique
y = pd.to_numeric(y, errors="coerce")

# On enlève les lignes où la target est manquante
mask = y.notna()
X = X.loc[mask]
y = y.loc[mask]


# --------------------------
# 4) TYPES DE VARIABLES
# --------------------------
# Random Forest ne comprend que des nombres.
# On doit donc :
# - garder les variables numériques telles quelles
# - transformer les variables catégorielles en nombres

cat_cols = X.select_dtypes(include=["object", "category", "bool"]).columns
num_cols = X.select_dtypes(include=["int64", "float64"]).columns

print("Variables numériques :", list(num_cols))
print("Variables catégorielles :", list(cat_cols))


# --------------------------
# 5) PRETRAITEMENT DES DONNEES
# --------------------------
# a) Variables numériques :
#    - on remplace les valeurs manquantes par la médiane
# b) Variables catégorielles :
#    - on remplace les valeurs manquantes par la modalité la plus fréquente
#    - on applique un One-Hot Encoding (0/1)

numeric_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="median"))
])

categorical_transformer = Pipeline(steps=[
    ("imputer", SimpleImputer(strategy="most_frequent")),
    ("onehot", OneHotEncoder(handle_unknown="ignore"))
])

# On assemble le tout
preprocess = ColumnTransformer(
    transformers=[
        ("num", numeric_transformer, num_cols),
        ("cat", categorical_transformer, cat_cols)
    ]
)


# --------------------------
# 6) LE MODELE : RANDOM FOREST
# --------------------------
# Une Random Forest est un ensemble d’arbres de décision.
#
# Chaque arbre :
# - voit une partie aléatoire des données
# - voit une partie aléatoire des variables
# - apprend des règles simples (si / alors)
#
# La prédiction finale = moyenne des prédictions de tous les arbres

model = RandomForestRegressor(
    n_estimators=300,     # nombre d’arbres dans la forêt
    random_state=42,      # pour des résultats reproductibles
    n_jobs=-1             # utilise tous les cœurs du CPU
)


# --------------------------
# 7) PIPELINE COMPLET
# --------------------------
# Le pipeline garantit que :
# - le même prétraitement est appliqué au train et au test
# - on évite les fuites de données (data leakage)

pipe = Pipeline(steps=[
    ("preprocess", preprocess),
    ("model", model)
])


# --------------------------
# 8) SEPARATION TRAIN / TEST
# --------------------------
# On entraîne le modèle sur une partie des données
# et on l’évalue sur des données jamais vues.

X_train, X_test, y_train, y_test = train_test_split(
    X, y,
    test_size=0.2,       # 20 % pour le test
    random_state=42
)


# --------------------------
# 9) ENTRAINEMENT DU MODELE
# --------------------------
# Le modèle apprend automatiquement :
# - quelles variables sont importantes
# - quelles combinaisons mènent à une forte fréquentation

pipe.fit(X_train, y_train)


# --------------------------
# 10) PREDICTIONS
# --------------------------
# Le modèle prédit la fréquentation sur les données de test

y_pred = pipe.predict(X_test)


# --------------------------
# 11) EVALUATION
# --------------------------
# MAE : erreur moyenne en nombre de visiteurs
# R²  : proportion de la variabilité expliquée

mae = mean_absolute_error(y_test, y_pred)
r2 = r2_score(y_test, y_pred)

print("MAE (erreur moyenne en visiteurs) :", round(mae, 2))
print("R² :", round(r2, 3))


# --------------------------
# 12) VERIFICATION CONCRETE DES RESULTATS
# --------------------------
# On compare valeurs réelles et prédites pour quelques musées

resultats = pd.DataFrame({
    "Frequentation_reelle": y_test.values[:15],
    "Frequentation_predite": y_pred[:15],
    "Erreur_absolue": np.abs(y_test.values[:15] - y_pred[:15])
})

display(resultats)


# --------------------------
# 13) INTERPRETATION : IMPORTANCE DES VARIABLES
# --------------------------
# On peut voir quelles variables influencent le plus la prédiction

importances = pipe.named_steps["model"].feature_importances_
feature_names = pipe.named_steps["preprocess"].get_feature_names_out()

importance_df = (
    pd.DataFrame({
        "variable": feature_names,
        "importance": importances
    })
    .sort_values("importance", ascending=False)
    .head(15)
)

display(importance_df)
